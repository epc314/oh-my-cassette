# Cassette
CASSETTE_URL=https://sg.trycassette.online/agent
CASSETTE_AUTH_EMAIL=you@example.com
CASSETTE_AUTH_PASSWORD=your-generated-cassette-password
CASSETTE_ASSET_ROOT=$HOME/.hermes/cassette
CASSETTE_HEADLESS=true
CASSETTE_FORCE_H264=true
CASSETTE_FORCE_H264_PLATFORMS=weixin,qqbot,qq,telegram,web
# Optional: browser job timeout. Upload/analysis waits inherit this by default.
CASSETTE_BROWSER_TIMEOUT_SEC=1800
# Optional: set a separate upload/analysis timeout in seconds; set 0 only to wait forever.
CASSETTE_UPLOAD_TIMEOUT_SEC=

# Optional: add custom gateway media cache directories.
CASSETTE_ALLOWED_SOURCE_ROOTS=$HOME/.hermes/qqbot:$HOME/.hermes/telegram:$HOME/.hermes/cache:$HOME/.hermes/tmp

# Cassette transport. 'api' (DEFAULT) calls the Cassette server APIs directly (no browser) — it needs
# an account with full API access (see below). Set 'browser' to drive the Cassette web UI with
# Playwright instead. Both are fully supported; choose per deployment. Leave unset for the api default.
CASSETTE_TRANSPORT=api
# Optional: override the render-server API origin used by the 'api' transport. Defaults to the
# deployed Cassette API, so you normally do NOT need to set this. It is the host serving
# /api/agent-auth, /api/media, /api/langgraph, /api/projects and /api/export — NOT the /agent editor
# route in CASSETTE_URL. Set it only for self-hosted / non-default deployments.
# CASSETTE_API_URL=https://remotion-canvas-server-5tdb2hkb4q-as.a.run.app
# Optional: agent model id for the 'api' transport (the agent requires an explicit model). Must be a
# product-supported Cassette model (deepseek/deepseek-v4-flash, deepseek/deepseek-v4-pro,
# openai/gpt-5.4-mini); defaults to deepseek/deepseek-v4-flash (the editor's default model).
# CASSETTE_API_MODEL_ID=deepseek/deepseek-v4-flash
# Optional ('api' transport): seconds a run may stay 'pending' before failing fast with
# 'agent_run_not_started' (the LangGraph queue is not draining). Default 120.
# CASSETTE_API_RUN_START_TIMEOUT_SEC=120
# Optional ('api' transport): seconds to wait for uploaded media to become fully processed
# (analysis evidence/embeddings for the agent + render-source derivative for the export) before
# starting the run. Prevents empty edits / "render-source is missing" exports. Default 300.
# CASSETTE_API_MEDIA_READY_TIMEOUT_SEC=300
# Optional ('api' transport): separate render/export budget in seconds; defaults to the job timeout.
# CASSETTE_EXPORT_TIMEOUT_SEC=
# Optional ('api' transport): auto-answer *routine* Cassette questions is automatic; setting this
# also auto-answers genuine ask_user choices with this reply instead of returning needs_user.
# CASSETTE_API_DEFAULT_ASK_USER_REPLY=
# Optional ('api' transport): export directly on a successful agent run instead of routing completion
# through the Hermes supervisor review (cassette_review_completion). Off by default = browser parity.
# CASSETTE_API_AUTO_EXPORT=false
# Optional ('api' transport): extract a still frame from the exported mp4 as final_screenshot (the api
# path has no browser to screenshot). Default on; set to 0 to disable.
# CASSETTE_API_EXPORT_THUMBNAIL=true

# Optional: web demo LLM provider.
DEEPSEEK_API_KEY=your_deepseek_api_key
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash
OMC_WEB_HOST=0.0.0.0
OMC_WEB_PORT=8080

# Optional: smart BGM.
CASSETTE_SMART_BGM_ENABLED=true
CASSETTE_EXACT_BGM_ENABLED=true
CASSETTE_EXACT_BGM_SOURCES=netease,qq,kuwo,joox
JAMENDO_CLIENT_ID=your_client_id
JAMENDO_CLIENT_SECRET=your_client_secret

# Optional: override JOOX token only if the built-in public token stops working.
CASSETTE_EXACT_BGM_JOOX_TOKEN=override_joox_token_if_needed
