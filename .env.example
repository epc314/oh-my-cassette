# Cassette
CASSETTE_URL=https://sg.trycassette.online/agent
CASSETTE_AUTH_EMAIL=you@example.com
CASSETTE_AUTH_PASSWORD=your-generated-cassette-password
CASSETTE_ASSET_ROOT=$HOME/.hermes/cassette
CASSETTE_HEADLESS=true
CASSETTE_FORCE_H264=true
CASSETTE_FORCE_H264_PLATFORMS=weixin,qqbot,qq,telegram,web
# Optional: browser job timeout. Upload/analysis waits inherit this by default.
CASSETTE_BROWSER_TIMEOUT_SEC=1800
# Optional: set a separate upload/analysis timeout in seconds; set 0 only to wait forever.
CASSETTE_UPLOAD_TIMEOUT_SEC=

# Optional: add custom gateway media cache directories.
CASSETTE_ALLOWED_SOURCE_ROOTS=$HOME/.hermes/qqbot:$HOME/.hermes/telegram:$HOME/.hermes/cache:$HOME/.hermes/tmp

# Optional (experimental): Cassette transport. 'browser' (default) drives the Cassette web UI
# with Playwright; 'api' calls the Cassette server APIs directly (no browser). Leave unset for
# the default browser transport.
CASSETTE_TRANSPORT=browser
# Optional: override the render-server API origin used by the 'api' transport. Defaults to the
# deployed Cassette API, so you normally do NOT need to set this. It is the host serving
# /api/agent-auth, /api/media, /api/langgraph, /api/projects and /api/export — NOT the /agent editor
# route in CASSETTE_URL. Set it only for self-hosted / non-default deployments.
# CASSETTE_API_URL=https://remotion-canvas-server-5tdb2hkb4q-as.a.run.app

# Optional: web demo LLM provider.
DEEPSEEK_API_KEY=your_deepseek_api_key
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash
OMC_WEB_HOST=0.0.0.0
OMC_WEB_PORT=8080

# Optional: smart BGM.
CASSETTE_SMART_BGM_ENABLED=true
CASSETTE_EXACT_BGM_ENABLED=true
CASSETTE_EXACT_BGM_SOURCES=netease,qq,kuwo,joox
JAMENDO_CLIENT_ID=your_client_id
JAMENDO_CLIENT_SECRET=your_client_secret

# Optional: override JOOX token only if the built-in public token stops working.
CASSETTE_EXACT_BGM_JOOX_TOKEN=override_joox_token_if_needed
