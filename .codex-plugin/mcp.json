{
  "mcpServers": {
    "cassette": {
      "command": "python3",
      "args": [
        "-c",
        "import os, runpy, sys; from pathlib import Path; home = Path(os.environ.get('CODEX_HOME') or (Path.home() / '.codex')); base = home / 'plugins' / 'cache' / 'cassette-editor' / 'oh-my-cassette'; candidates = [path for path in base.glob('*/scripts/run_local_mcp.py') if path.is_file()]; candidates or sys.exit(f'oh-my-cassette: no installed plugin copy under {base}; reinstall with: codex plugin add oh-my-cassette@cassette-editor'); runpy.run_path(str(max(candidates, key=lambda path: path.stat().st_mtime_ns)), run_name='__main__')"
      ],
      "env": {
        "CASSETTE_MCP_HOST": "codex"
      },
      "env_vars": [
        "CODEX_HOME",
        "XDG_CONFIG_HOME",
        "XDG_DATA_HOME",
        "CASSETTE_CONFIG_HOME",
        "CASSETTE_DATA_HOME",
        "CASSETTE_ASSET_ROOT",
        "CASSETTE_PROJECT_ROOT",
        "CASSETTE_PROJECT_ROOTS",
        "CASSETTE_ALLOWED_SOURCE_ROOTS",
        "CASSETTE_ALLOWED_EXTENSIONS",
        "CASSETTE_MAX_BYTES",
        "CASSETTE_AUTH_EMAIL",
        "CASSETTE_AUTH_ACCOUNT",
        "CASSETTE_AUTH_PASSWORD",
        "CASSETTE_EMAIL",
        "CASSETTE_PASSWORD",
        "CASSETTE_TRANSPORT",
        "CASSETTE_URL",
        "CASSETTE_API_URL",
        "CASSETTE_API_BASE_URL",
        "CASSETTE_API_MODEL_ID",
        "CASSETTE_API_THINKING",
        "CASSETTE_API_HTTP_TIMEOUT_SEC",
        "CASSETTE_API_POLL_INTERVAL_SEC",
        "CASSETTE_API_RUN_START_TIMEOUT_SEC",
        "CASSETTE_API_MEDIA_READY_TIMEOUT_SEC",
        "CASSETTE_API_RECURSION_LIMIT",
        "CASSETTE_API_DEFAULT_ASK_USER_REPLY",
        "CASSETTE_API_AUTO_EXPORT",
        "CASSETTE_API_EXPORT_THUMBNAIL",
        "CASSETTE_AGENT_SOFT_RETRY_LIMIT",
        "CASSETTE_EXPORT_ON_COMPLETE",
        "CASSETTE_EXPORT_RETRY_LIMIT",
        "CASSETTE_EXPORT_TIMEOUT_SEC",
        "CASSETTE_UPLOAD_TIMEOUT_SEC",
        "CASSETTE_BROWSER_TIMEOUT_SEC",
        "CASSETTE_MIN_BROWSER_TIMEOUT_SEC",
        "CASSETTE_BROWSER_SESSION_REUSE",
        "CASSETTE_BROWSER_WORKER_THREAD",
        "CASSETTE_HEADLESS",
        "CASSETTE_NO_SANDBOX",
        "CASSETTE_CHAT_SUBMIT_VERIFY_SEC",
        "CASSETTE_NEW_CHAT_READY_TIMEOUT_SEC",
        "CASSETTE_FFMPEG_BIN",
        "CASSETTE_FFPROBE_BIN",
        "PLAYWRIGHT_BROWSERS_PATH",
        "CASSETTE_SMART_BGM_ENABLED",
        "CASSETTE_FREETOUSE_API_BASE",
        "CASSETTE_FREETOUSE_DATA_BASE",
        "CASSETTE_FREETOUSE_TIMEOUT_SEC",
        "CASSETTE_FREETOUSE_MAX_BYTES",
        "CASSETTE_EXACT_BGM_ENABLED",
        "CASSETTE_EXACT_BGM_SOURCES",
        "CASSETTE_EXACT_BGM_TIMEOUT_SEC",
        "CASSETTE_EXACT_BGM_MAX_BYTES",
        "CASSETTE_EXACT_BGM_SEARCH_LIMIT",
        "CASSETTE_EXACT_BGM_NETEASE_BASE",
        "CASSETTE_EXACT_BGM_QQ_BASE",
        "CASSETTE_EXACT_BGM_KUWO_BASE",
        "CASSETTE_EXACT_BGM_KUWO_LEVEL",
        "CASSETTE_EXACT_BGM_JOOX_BASE",
        "CASSETTE_EXACT_BGM_JOOX_BR",
        "CASSETTE_EXACT_BGM_JOOX_TOKEN",
        "JAMENDO_BASE_URL",
        "JAMENDO_CLIENT_ID",
        "JAMENDO_CLIENT_SECRET",
        "CASSETTE_MCP_PYTHON",
        "CASSETTE_MCP_SKIP_BOOTSTRAP",
        "CASSETTE_MCP_SETUP_COMMAND",
        "CASSETTE_MCP_MONITOR_BUDGET_SEC",
        "CASSETTE_MCP_NOTIFY"
      ],
      "startup_timeout_sec": 240,
      "tool_timeout_sec": 1800
    }
