# Copy this file to /etc/oh-my-cassette-web.env or export the same variables
# before starting `python -m web_demo.server`.
#
# Use absolute paths in systemd EnvironmentFile values; shell expansion such as
# $HOME is not guaranteed there.
# Quote values that contain shell-special characters, spaces, or `#` if you load
# this file with `. ./oh-my-cassette-web.env`.

CASSETTE_URL='https://sg.trycassette.online/agent'
CASSETTE_AUTH_EMAIL='you@example.com'
CASSETTE_AUTH_PASSWORD='your-cassette-password'
CASSETTE_ASSET_ROOT='/home/ubuntu/.oh-my-cassette/cassette'
CASSETTE_HEADLESS=true
CASSETTE_FORCE_H264=true
CASSETTE_ALLOWED_SOURCE_ROOTS='/home/ubuntu/.oh-my-cassette/cassette/web_uploads'
CASSETTE_MAX_BYTES=2147483648

DEEPSEEK_API_KEY='your_deepseek_api_key'
DEEPSEEK_BASE_URL='https://api.deepseek.com'
DEEPSEEK_MODEL='deepseek-v4-flash'
DEEPSEEK_TIMEOUT_SEC=120

OMC_WEB_HOST='0.0.0.0'
OMC_WEB_PORT=8080
OMC_WEB_LOG_DIR='/home/ubuntu/oh-my-cassette/web_demo/logs'
